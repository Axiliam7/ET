# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ET-ATS?retryWrites=true&w=majority

# JWT secret for signing/verifying tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Port for the Express backend (default: 4000)
PORT=4000
