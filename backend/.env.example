# Firebase Admin credentials are loaded from ../firebase-service-account.json.
# Download this JSON from Firebase Console > Project settings > Service accounts.
# Do not commit real credentials to source control.
# Optional override: set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# JWT secret for signing/verifying tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Port for the Express backend (default: 4000)
PORT=4000
